{
  "name": "agent-starter-kit",
  "version": "0.2.1",
  "private": false,
  "description": "A TypeScript starter for building and shipping AI agent products.",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/src/index.js",
    "demo": "tsx examples/claude-openai-mcp.ts",
    "demo:claude": "tsx examples/claude-openai-mcp.ts --provider claude",
    "demo:openai": "tsx examples/claude-openai-mcp.ts --provider openai",
    "check": "npm run build",
    "test": "tsx --test examples/claude-openai-mcp.test.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "starter",
    "typescript",
    "mcp",
    "llm",
    "claude",
    "openai"
  ],
  "author": "ue12233",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-filesystem": "^2026.1.14",
    "@types/node": "^25.6.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.3"
  }
}
